# PostgreSQL — Supabase
# Transaction pooler (IPv4, para uso en runtime)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/DATABASE?pgbouncer=true"
# Session pooler (para migraciones con prisma db push)
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"

# MongoDB — Atlas
MONGO_URI="mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/?appName=APPNAME"

PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET="your_super_secret_key_here"
JWT_EXPIRES_IN="7d"

# CORS — se configurará al integrar el frontend
CORS_ORIGIN="*"

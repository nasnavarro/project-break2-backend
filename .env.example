PORT=3000
NODE_ENV=development

# PostgreSQL — Supabase Session Pooler (IPv4, puerto 6543)
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://user:password@host:5432/postgres"

# MongoDB Atlas
MONGO_URI="mongodb+srv://user:password@cluster.mongodb.net/?appName=AppName"

# JWT
JWT_SECRET="cambia_esto_por_un_secreto_seguro"
JWT_EXPIRES_IN="7d"

# CORS — en desarrollo puede dejarse vacío (usa * como fallback)
# En producción, poner la URL del frontend: https://mi-frontend.vercel.app
CORS_ORIGIN=

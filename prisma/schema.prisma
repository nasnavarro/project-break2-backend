generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id          Int         @id @default(autoincrement())
  name        String
  description String?
  price       Float
  stock       Int
  imageUrl    String?
  createdAt   DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime    @updatedAt @db.Timestamptz(6)
  cartItems   CartItem[]
  orderItems  OrderItem[]

  @@map("products")
}

model users {
  id         Int       @id @default(autoincrement())
  email      String?   @unique @db.VarChar(100)
  password   String?   @db.VarChar(255)
  role       Role      @default(USER)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  carts      Cart[]
}

// Carrito activo del usuario. Un usuario solo puede tener un carrito ACTIVE.
// Al hacer checkout pasa a CHECKED_OUT y queda como historial.
model Cart {
  id        String     @id @default(uuid())
  userId    Int
  status    CartStatus @default(ACTIVE)
  createdAt DateTime   @default(now()) @db.Timestamptz(6)
  items     CartItem[]
  user      users      @relation(fields: [userId], references: [id])

  @@map("carts")
}

// Cada línea del carrito: qué producto y cuántas unidades.
// Si el usuario añade el mismo producto dos veces, se acumula la cantidad.
model CartItem {
  id        String  @id @default(uuid())
  cartId    String
  productId Int
  quantity  Int
  cart      Cart    @relation(fields: [cartId], references: [id])
  product   Product @relation(fields: [productId], references: [id])

  @@map("cart_items")
}

// Pedido creado al hacer checkout. Inmutable: registra el total y el detalle de líneas en ese momento.
model Order {
  id        String      @id @default(uuid())
  userId    Int
  total     Float
  createdAt DateTime    @default(now()) @db.Timestamptz(6)
  items     OrderItem[]

  @@map("orders")
}

// Línea de pedido: qué producto, cuántas unidades y a qué precio se compró.
model OrderItem {
  id              String  @id @default(uuid())
  orderId         String
  productId       Int
  quantity        Int
  priceAtPurchase Float
  order           Order   @relation(fields: [orderId], references: [id])
  product         Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

enum CartStatus {
  ACTIVE
  CHECKED_OUT
}

enum Role {
  USER
  ADMIN
}
